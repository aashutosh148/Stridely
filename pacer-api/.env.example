# Server Configuration
PORT=3001
ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pacer?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here-min-32-chars

# Encryption (AES-256 - must be 64 hex characters / 32 bytes)
ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OAuth - Strava
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# OAuth - Garmin
GARMIN_CLIENT_ID=your-garmin-client-id
GARMIN_CLIENT_SECRET=your-garmin-client-secret

# LLM Provider Configuration
# Supported providers: "anthropic", "openai", "gemini"
LLM_PROVIDER=anthropic
# Optional: Specify a model (uses provider default if not set)
LLM_MODEL=

# Anthropic API (for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API (for GPT models and embeddings)
OPENAI_API_KEY=your-openai-api-key

# Google Gemini API (for Gemini models)
GEMINI_API_KEY=your-gemini-api-key

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Sentry
SENTRY_DSN=your-sentry-dsn

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API URL (for OAuth callbacks)
API_URL=http://localhost:3001
